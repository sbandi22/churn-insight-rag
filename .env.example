# Copy to .env and fill in. .env is gitignored.
# All keys are OPTIONAL: the system runs fully offline with sentence-transformers.

# --- LLM (only needed for generated answers; retrieval works without it) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings ---
# Set to "openai" to use text-embedding-3-small, or "local" for all-MiniLM-L6-v2 (default, no key).
EMBEDDING_BACKEND=local
EMBEDDING_MODEL_LOCAL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_OPENAI=text-embedding-3-small

# --- Vector store ---
CHROMA_DIR=.chroma
CHROMA_COLLECTION=churn_insight
